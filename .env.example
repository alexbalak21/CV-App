FLASK_APP=wsgi.py
FLASK_CONFIG=dev
SECRET_KEY=change-me-to-a-random-value

# --- MySQL, option A: component variables ---
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=cv_app

# --- MySQL, option B: one connection string (wins if set) ---
# DATABASE_URL=mysql+pymysql://root:@localhost/cv_app?charset=utf8mb4

# --- SQLite (default if neither of the above is set) ---
# DATABASE_URL=sqlite:///instance/app.db

# --- PostgreSQL (future option, see plan.md) ---
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/cvapp
